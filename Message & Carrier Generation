import numpy as np
import matplotlib.pyplot as plt

fs = 1000  # Sampling frequency
t = np.arange(0, 1, 1/fs)


mt = 1 * np.cos(2*np.pi * 2 * t)
ct = 2 * np.cos(2*np.pi * 50 * t)


# AM Modulation: s(t)=[Ac+m(t)]cos(Wc*t)
Ac = 2
st = (Ac+mt)*np.cos(2*np.pi*50*t)
#Adding noise and creating envelope detector
noise = np.random.normal(0,0.2,len(st))
rt = st + noise
rectified_signal = np.abs(rt) # the positive half of the signal bc of the diode
window_size = 30 # to change RC 
demodulated_signal = np.convolve(rectified_signal, np.ones(window_size)/window_size, mode='same') # Low pass filter

#FM Modulation: s(t)=Ac*cos(2*pi*fc*t + bita*sin(2*pi*fm*t))
Ac1 = 1
st_fm = Ac1 * np.cos(2*np.pi*50*t + 10*np.sin(2*np.pi*2*t))

#FM Demodulation using differentiation and envelope detection
derived_signal = np.diff(st_fm)/(1/fs)
derived_signal = np.insert(derived_signal, 0, 0) # to maintain the same length
rectified_fm_signal = np.abs(derived_signal) # the positive half of the signal bc of the diode
demodulated_signal_fm = np.convolve(rectified_fm_signal, np.ones(window_size)/window_size, mode='same') # Low pass filter




# AM Modulation and Demodulation
plt.figure(figsize=(10, 8))
plt.subplot(4, 1, 1)
plt.plot(t, mt)
plt.title('Message Signal (mt)')
plt.xlabel('Time [s]')
plt.ylabel('Amplitude')

plt.subplot(4,1,2)
plt.plot(t, ct)
plt.title('Carrier Signal (ct)')
plt.xlabel('Time [s]')
plt.ylabel('Amplitude')

plt.subplot(4,1,3)
plt.plot(t, st)
plt.title('AM Modulated Signal (st)')
plt.xlabel('Time [s]')
plt.ylabel('Amplitude')

plt.subplot(4,1,4)
plt.plot(t, demodulated_signal)
plt.title('Demodulated Signal (Envelope)')
plt.xlabel('Time [s]')
plt.ylabel('Amplitude')






#FM Modulation and Demodulation
plt.figure(figsize=(10, 4))
plt.subplot(3,1,1)
plt.plot(t, mt)
plt.title('Message Signal (mt)')
plt.xlabel('Time [s]')
plt.subplot(3,1,2)
plt.plot(t, st_fm)
plt.title('FM Modulated Signal (st_fm)')
plt.xlabel('Time [s]')
plt.subplot(3,1,3)
plt.plot(t, demodulated_signal_fm)
plt.title('Demodulated Signal (FM)')
plt.xlabel('Time [s]')
plt.ylabel('Amplitude')





plt.tight_layout()
plt.show()